// DigitalCAD Training - Complete Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SessionType {
  THEORY
  CAD
  BOTH
}

enum BatchStatus {
  PENDING_APPROVAL
  UPCOMING
  ACTIVE
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ScheduledSessionStatus {
  UPCOMING
  LIVE
  COMPLETED
  CANCELLED
}

enum SubmissionStatus {
  SUBMITTED
  REVIEWED
  RESUBMIT
}

enum QueryStatus {
  OPEN
  RESOLVED
  AUTO_RESOLVED
}

enum OtpPurpose {
  STUDENT_REGISTER
  TUTOR_REGISTER
  LOGIN
  PASSWORD_RESET
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String   @unique
  password_hash String
  role          Role     @default(STUDENT)
  is_verified   Boolean  @default(false)
  is_active     Boolean  @default(true)
  avatar_url    String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  enrollments       Enrollment[]
  tutor_application TutorApplication?
  tutor_batches     Batch[]            @relation("TutorBatches")
  submissions       AssignmentSubmission[]
  queries           Query[]
  refresh_tokens    RefreshToken[]

  @@map("users")
}

model OtpVerification {
  id         String     @id @default(cuid())
  phone      String
  otp        String
  purpose    OtpPurpose
  expires_at DateTime
  is_used    Boolean    @default(false)
  attempts   Int        @default(0)
  created_at DateTime   @default(now())

  @@index([phone, purpose])
  @@map("otp_verifications")
}

model Course {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  short_name      String
  description     String
  duration_months Int
  price           Decimal  @db.Decimal(10, 2)
  overview_points Json     @default("[]")
  tools_covered   Json     @default("[]")
  is_active       Boolean  @default(true)
  thumbnail_url   String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  batches            Batch[]
  tutor_applications TutorApplication[]

  @@map("courses")
}

model TutorApplication {
  id              String @id @default(cuid())
  name            String
  email           String
  phone           String
  occupation      String
  years_exp       Int
  companies       String
  work_experience String
  course_id       String
  course          Course @relation(fields: [course_id], references: [id])
  time_slots      Json   @default("[]")
  hide_identity   Boolean           @default(false)
  location        String
  languages       Json              @default("[]")
  status          ApplicationStatus @default(PENDING)
  applied_on      DateTime          @default(now())
  reviewed_on     DateTime?
  rejection_note  String?
  user_id         String?           @unique
  user            User?             @relation(fields: [user_id], references: [id])
  syllabus_sessions SyllabusTemplate[]
  syllabus_projects SyllabusProject[]

  @@map("tutor_applications")
}

model SyllabusTemplate {
  id             String           @id @default(cuid())
  application_id String
  application    TutorApplication @relation(fields: [application_id], references: [id])
  session_number Int
  name           String
  type           SessionType      @default(BOTH)

  @@map("syllabus_templates")
}

model SyllabusProject {
  id             String           @id @default(cuid())
  application_id String
  application    TutorApplication @relation(fields: [application_id], references: [id])
  name           String
  highlights     Json             @default("[]")

  @@map("syllabus_projects")
}

model Batch {
  id           String      @id @default(cuid())
  course_id    String
  course       Course      @relation(fields: [course_id], references: [id])
  tutor_id     String
  tutor        User        @relation("TutorBatches", fields: [tutor_id], references: [id])
  name         String
  start_date   DateTime
  end_date     DateTime
  max_students Int         @default(50)
  description  String?
  zoom_link    String?
  time_slots   Json        @default("[]")
  status       BatchStatus @default(PENDING_APPROVAL)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  enrollments        Enrollment[]
  scheduled_sessions ScheduledSession[]
  assignments        Assignment[]

  @@map("batches")
}

model Enrollment {
  id             String        @id @default(cuid())
  student_id     String
  student        User          @relation(fields: [student_id], references: [id])
  batch_id       String
  batch          Batch         @relation(fields: [batch_id], references: [id])
  enrolled_at    DateTime      @default(now())
  payment_status PaymentStatus @default(PENDING)
  payment_ref    String?
  progress       Int           @default(0)

  @@unique([student_id, batch_id])
  @@map("enrollments")
}

model ScheduledSession {
  id               String                 @id @default(cuid())
  batch_id         String
  batch            Batch                  @relation(fields: [batch_id], references: [id])
  session_number   Int
  name             String
  type             SessionType            @default(BOTH)
  scheduled_at     DateTime?
  duration_minutes Int                    @default(90)
  zoom_link        String?
  recording_url    String?
  notes_url        String?
  status           ScheduledSessionStatus @default(UPCOMING)
  created_at       DateTime               @default(now())

  assignments Assignment[]
  queries     Query[]

  @@map("scheduled_sessions")
}

model Assignment {
  id          String           @id @default(cuid())
  batch_id    String
  batch       Batch            @relation(fields: [batch_id], references: [id])
  session_id  String?
  session     ScheduledSession? @relation(fields: [session_id], references: [id])
  title       String
  description String?
  file_url    String?
  due_date    DateTime?
  created_at  DateTime         @default(now())

  submissions AssignmentSubmission[]

  @@map("assignments")
}

model AssignmentSubmission {
  id            String           @id @default(cuid())
  assignment_id String
  assignment    Assignment       @relation(fields: [assignment_id], references: [id])
  student_id    String
  student       User             @relation(fields: [student_id], references: [id])
  file_url      String
  submitted_at  DateTime         @default(now())
  status        SubmissionStatus @default(SUBMITTED)
  grade         String?
  feedback      String?
  reviewed_at   DateTime?

  @@unique([assignment_id, student_id])
  @@map("assignment_submissions")
}

model Query {
  id          String            @id @default(cuid())
  student_id  String
  student     User              @relation(fields: [student_id], references: [id])
  session_id  String?
  session     ScheduledSession? @relation(fields: [session_id], references: [id])
  batch_id    String
  question    String
  media_url   String?
  answer      String?
  status      QueryStatus       @default(OPEN)
  is_reminded Boolean           @default(false)
  reminded_at DateTime?
  created_at  DateTime          @default(now())
  answered_at DateTime?

  @@map("queries")
}

model RefreshToken {
  id         String   @id @default(cuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())

  @@map("refresh_tokens")
}