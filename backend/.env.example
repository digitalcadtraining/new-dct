# ─────────────────────────────────────────────────────────
# DigitalCAD Training - Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ─────────────────────────────────────────────────────────

# ── SERVER ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development              # development | production

# ── DATABASE (PostgreSQL) ─────────────────────────────────
# Local: postgresql://USER:PASSWORD@localhost:5432/dct_db
# Neon / Supabase / Railway also work fine
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/dct_db"

# ── JWT ──────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="your-very-long-access-secret-here"
JWT_REFRESH_SECRET="your-very-long-refresh-secret-here"
JWT_ACCESS_EXPIRES="15m"          # Access token: 15 minutes
JWT_REFRESH_EXPIRES="7d"          # Refresh token: 7 days

# ── OTP / SMS (MSG91 - popular in India) ─────────────────
# Sign up at msg91.com and get these values
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_SENDER_ID="DCTTRN"
MSG91_TEMPLATE_ID="your-template-id"
OTP_EXPIRES_MINUTES=10            # OTP valid for 10 minutes
OTP_MAX_ATTEMPTS=3                # Max wrong attempts before lockout

# ── FILE UPLOADS (Cloudinary) ────────────────────────────
# Free tier at cloudinary.com (25GB storage)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── FRONTEND URL (for CORS) ──────────────────────────────
FRONTEND_URL="http://localhost:5173"     # Vite dev server
# FRONTEND_URL="https://digitalcadtraining.com"  # Production

# ── ADMIN (first admin account, created on first run) ────
ADMIN_EMAIL="admin@digitalcadtraining.com"
ADMIN_PASSWORD="ChangeThisPassword@123"
ADMIN_NAME="Super Admin"
ADMIN_PHONE="9876543210"

# ── RATE LIMITING ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000       # 15 minutes
RATE_LIMIT_MAX=100                # 100 requests per window per IP
OTP_RATE_LIMIT_MAX=5              # 5 OTP requests per 15 min per phone
